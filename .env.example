# AI Virtual Agency - Environment Variables

# AI Provider Selection: google | openai | anthropic | ollama | mock
VITE_AI_PROVIDER=mock

# Google Gemini API Key
VITE_GOOGLE_API_KEY=

# OpenAI API Key (Optional, for future implementation)
VITE_OPENAI_API_KEY=

# Anthropic API Key (Optional, for future implementation)
VITE_ANTHROPIC_API_KEY=

# Ollama Base URL (Optional, for future implementation)
VITE_OLLAMA_BASE_URL=http://localhost:11434
